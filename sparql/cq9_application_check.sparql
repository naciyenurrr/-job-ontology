# CQ9 — Has a given candidate applied for a given job?
# Change :Naciye and :JuniorDataAnalystJob as needed.

PREFIX : <http://www.example.org/jobontology#>

ASK {
    :Naciye :appliesTo :JuniorDataAnalystJob .
}

